RewriteEngine On
RewriteBase /clinica_pura/public/

# 1. Permitir acceso a archivos estáticos (CSS, JS, Imágenes)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# 2. Redirección al Front Controller
# Eliminamos el ^(.*)$ genérico por uno que sea más amigable con los parámetros
RewriteRule ^([\w\-/]+)/?$ index.php?action=$1 [L,QSA]

# 3. Regla de respaldo para la raíz
RewriteRule ^$ index.php?action=dashboard [L,QSA]